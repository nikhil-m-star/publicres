generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CITIZEN
  OFFICER
  PRESIDENT
}

enum Category {
  POTHOLE
  GARBAGE
  STREETLIGHT
  WATER_LEAK
  BRIBERY
  OTHER
}

enum Status {
  REPORTED
  IN_PROGRESS
  RESOLVED
}

model User {
  id            String    @id @default(cuid())
  clerkId       String    @unique
  name          String
  email         String    @unique
  role          Role      @default(CITIZEN)
  city          String?   @default("Bengaluru") // Defaulting to Bengaluru for now
  area          String?   // Officer's assigned area
  avgRating     Float     @default(0)
  resolvedCount Int       @default(0)
  assignedCount Int       @default(0)
  createdAt     DateTime  @default(now())

  issues         Issue[]   @relation("CreatedIssues")
  assignedIssues Issue[]   @relation("AssignedIssues")
  resolvedIssues Issue[]   @relation("ResolvedIssues")
  votes          Vote[]
  comments       Comment[]
  ratingsGiven   Rating[]  @relation("RatingGiver")
  ratingsReceived Rating[] @relation("RatingReceiver")
  notifications  Notification[]

  @@map("users")
}

model Issue {
  id          String   @id @default(cuid())
  title       String
  description String
  category    Category
  status      Status   @default(REPORTED)
  city        String   @default("Bengaluru")
  area        String?
  latitude    Float
  longitude   Float
  imageUrl    String?
  department  String?
  intensity   Float?   // AI scored 1-10
  votes       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy    User    @relation("CreatedIssues", fields: [createdById], references: [id])
  createdById  String

  assignedTo   User?   @relation("AssignedIssues", fields: [assignedToId], references: [id])
  assignedToId String?

  resolvedBy   User?   @relation("ResolvedIssues", fields: [resolvedById], references: [id])
  resolvedById String?

  voteRecords Vote[]
  comments    Comment[]
  ratings     Rating[]
  notifications Notification[]

  @@map("issues")
}

model Notification {
  id        String   @id @default(cuid())
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String

  issue     Issue?   @relation(fields: [issueId], references: [id], onDelete: SetNull)
  issueId   String?

  @@map("notifications")
}

model Vote {
  id      String @id @default(cuid())
  issue   Issue  @relation(fields: [issueId], references: [id], onDelete: Cascade)
  issueId String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId  String

  @@unique([issueId, userId])
  @@map("votes")
}

model Comment {
  id        String   @id @default(cuid())
  comment   String
  createdAt DateTime @default(now())

  issue   Issue  @relation(fields: [issueId], references: [id], onDelete: Cascade)
  issueId String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId  String

  @@map("comments")
}

model Rating {
  id        String   @id @default(cuid())
  score     Int      // 1-5 stars
  feedback  String?
  createdAt DateTime @default(now())

  issue   Issue?  @relation(fields: [issueId], references: [id], onDelete: Cascade)
  issueId String?

  givenBy   User   @relation("RatingGiver", fields: [givenById], references: [id])
  givenById String

  officer   User   @relation("RatingReceiver", fields: [officerId], references: [id])
  officerId String

  @@unique([issueId, givenById]) // one rating per issue per user (Postgres allows multiple nulls)
  @@map("ratings")
}
